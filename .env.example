# ── Notion ────────────────────────────────────────────────────────────────

# Internal integration token (https://www.notion.so/profile/integrations).
# The integration MUST have the "Read user information including email
# addresses" capability enabled, plus Read/Update/Insert content.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 32-char hex id of the tasks database (open the DB in Notion, copy from URL).
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — override default property names if your schema differs.
# NOTION_PROP_TITLE=Name
# NOTION_PROP_DATE=Date
# NOTION_PROP_OWNER=Owner

# Optional — Status / Select property name used to flag archived tasks. Leave
# empty to disable status-based archival detection.
# NOTION_PROP_STATUS=Status

# CSV of status values that should trigger event deletion.
# NOTION_STATUS_ARCHIVED_VALUES=Archived,Done,Cancelled

# ── Google Workspace — service account with Domain-Wide Delegation ────────

GOOGLE_SA_EMAIL=notion-sync@your-project.iam.gserviceaccount.com

# PEM private key. On Railway, paste the raw key — the code normalises literal
# "\n" back to real newlines before PKCS8 import.
GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...==\n-----END PRIVATE KEY-----\n"

# CSV of user emails whose primary calendar we ingest events from (G→N).
# Leave empty to disable the G→N direction (N→G still runs).
# GOOGLE_WATCH_EMAILS=alice@example.com,bob@example.com

# Prefix marker (case-insensitive, word-boundary) that triggers initial G→N
# ingestion. Stripped from the event title when the Notion page is created.
# GOOGLE_SYNC_KEYWORD=NOTION
#
# Google Calendar event color applied on every N→G create/update (1–24).
# from 1 to 11
# GOOGLE_EVENT_COLOR_ID=2

# ── Sync behaviour ────────────────────────────────────────────────────────

# Default event length (minutes) when Notion task has no end time.
# DEFAULT_EVENT_DURATION_MIN=30

# Overlap window for the incremental Notion query (minutes).
# SYNC_LOOKBACK_MIN=15

# IANA timezone for dated events.
# SYNC_TIMEZONE=Europe/Paris

# Minimum hours between two internal reconcile runs.
# RECONCILE_INTERVAL_HOURS=24

# ── Storage & logs ────────────────────────────────────────────────────────

# SQLite path. `/data` is the Railway volume mount point.
# DATABASE_PATH=/data/sync.db

# debug | info | warn | error
# LOG_LEVEL=info
