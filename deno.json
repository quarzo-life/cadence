{
  "compilerOptions": {
    "strict": true
  },
  "imports": {
    "@std/dotenv": "jsr:@std/dotenv",
    "@notionhq/client": "npm:@notionhq/client@5.20",
    "@db/sqlite": "jsr:@db/sqlite@^0.13"
  },
  "tasks": {
    "dev": "deno run --allow-net --allow-env --allow-read --allow-write --allow-ffi --watch main.ts",
    "start": "deno run --allow-net --allow-env --allow-read --allow-write --allow-ffi main.ts",
    "reconcile": "deno run --allow-net --allow-env --allow-read --allow-write --allow-ffi main.ts reconcile",
    "test": "deno test --allow-all"
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  }
}
